{
  "name": "llama-recipe-manager",
  "version": "0.1.1",
  "description": "Llama Recipe Manager — manage and launch llama-server recipes",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Mohammad Ashar Khan",
    "email": "ashar786khan@gmail.com",
    "url": "https://github.com/coder3101"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coder3101/llama-recipe-manager.git"
  },
  "homepage": "https://github.com/coder3101/llama-recipe-manager#readme",
  "bugs": {
    "url": "https://github.com/coder3101/llama-recipe-manager/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "format:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "format:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "icons": "python3 scripts/make-icons.py",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2",
    "@tauri-apps/plugin-updater": "^2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^17.5.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
